# Copy to .env for local development and docker compose.
# cp .env.example .env   (PowerShell: Copy-Item .env.example .env)

NODE_ENV=development

# Postgres (docker-compose service: postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=verdiron
POSTGRES_PASSWORD=verdiron
POSTGRES_DB=verdiron

# RabbitMQ (docker-compose service: rabbitmq)
# Management UI: http://localhost:15672
RABBITMQ_USER=verdiron
RABBITMQ_PASSWORD=verdiron
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://verdiron:verdiron@localhost:5672

# AWS / LocalStack (docker-compose service: localstack)
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
LOCALSTACK_PORT=4566
LOCALSTACK_DEBUG=0

# Resource names (created by VRD-011 init scripts; defaults for local dev)
KINESIS_STREAM_NAME=telemetry
S3_BUCKET_NAME=verdiron-raw
DYNAMODB_TABLE_NAME=telemetry-hot

# API auth (services)
API_KEY=dev-api-key-change-me

# OpenTelemetry (docker-compose services: otel-collector, jaeger)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=verdiron-local
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318
JAEGER_UI_PORT=16686

# Services
INGESTION_PORT=3001
PROCESSING_PORT=3002
