{
  "name": "persistence",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/persistence/src",
  "projectType": "library",
  "tags": ["scope:shared"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/persistence",
        "main": "libs/persistence/src/index.ts",
        "tsConfig": "libs/persistence/tsconfig.lib.json",
        "assets": ["libs/persistence/*.md"]
      }
    },
    "integration-test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "libs/persistence/jest.integration.config.cjs",
        "runInBand": true
      }
    }
  }
}
